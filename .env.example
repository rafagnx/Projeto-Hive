# ============================================
# InstaPost AI - Environment Variables
# ============================================
# Copy: cp .env.example .env
# Then edit the values marked with CHANGE_ME

# === Database ===
DB_PASSWORD=CHANGE_ME_strong_password
DATABASE_URL=postgresql://instapost:CHANGE_ME_strong_password@localhost:5433/instapost
# For Docker production (services communicate internally):
# DATABASE_URL=postgresql://instapost:CHANGE_ME_strong_password@postgres:5432/instapost

# === Redis ===
REDIS_URL=redis://localhost:6379
# For Docker production:
# REDIS_URL=redis://redis:6379

# === JWT Authentication ===
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_random_secret
JWT_EXPIRES_IN=7d

# === Internal Service Token (bot + MCP auth) ===
# Generate: openssl rand -hex 24
INTERNAL_SERVICE_TOKEN=CHANGE_ME_generate_random_token

# === MinIO (S3-compatible Storage) ===
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_minio_secret
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_BUCKET=instapost-images

# === Frontend ===
FRONTEND_URL=http://localhost:3000
WEB_PORT=3000

# === MCP Server ===
MCP_AUTH_TOKEN=
MCP_PORT=3002

# === Instagram Graph API (optional) ===
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# === Facebook (optional) ===
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# === Image Generation - Google Gemini (optional) ===
NANO_BANANA_API_KEY=
NANO_BANANA_PROVIDER=google

# === Telegram Bot (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
